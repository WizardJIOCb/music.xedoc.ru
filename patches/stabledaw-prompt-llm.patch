+from __future__ import annotations
+
+import asyncio
+import logging
+import os
+import random
+import re
+import threading
+import time
+from typing import Any
+
+from fastapi import APIRouter, Body, HTTPException
+
+log = logging.getLogger(__name__)
+
+router = APIRouter()
+
+MODEL_ID = os.getenv("MUSIC_PROMPT_LLM_MODEL", "Qwen/Qwen2.5-0.5B-Instruct")
+MAX_PROMPT_CHARS = 1000
+
+_tokenizer: Any | None = None
+_model: Any | None = None
+_load_lock = threading.Lock()
+
+_SEEDS = [
+    "cyberpunk guitars and synth bass",
+    "cinematic drum and bass chase",
+    "dreamy synthwave road trip",
+    "dark industrial club",
+    "lo-fi jazz hop at midnight",
+    "epic trailer rock finale",
+    "space ambient rescue mission",
+    "mystical desert electronica",
+    "melancholic piano and strings",
+    "funky electro breakbeat",
+    "post-apocalyptic metal soundtrack",
+    "uplifting progressive house anthem",
+]
+
+
+def _get_model() -> tuple[Any, Any]:
+    global _tokenizer, _model
+    if _tokenizer is not None and _model is not None:
+        return _tokenizer, _model
+
+    with _load_lock:
+        if _tokenizer is not None and _model is not None:
+            return _tokenizer, _model
+
+        try:
+            import torch
+            from transformers import AutoModelForCausalLM, AutoTokenizer
+
+            log.info("prompt_llm: loading %s on CPU", MODEL_ID)
+            started = time.perf_counter()
+            tokenizer = AutoTokenizer.from_pretrained(MODEL_ID)
+            model = AutoModelForCausalLM.from_pretrained(MODEL_ID, torch_dtype=torch.float32)
+            model.to("cpu")
+            model.eval()
+            _tokenizer = tokenizer
+            _model = model
+            log.info("prompt_llm: %s loaded in %.2fs", MODEL_ID, time.perf_counter() - started)
+        except Exception as exc:
+            log.exception("prompt_llm: failed to load %s", MODEL_ID)
+            raise HTTPException(status_code=503, detail=f"Prompt LLM is unavailable: {exc}") from exc
+
+    return _tokenizer, _model
+
+
+def _clean_prompt(text: str) -> str:
+    value = str(text or "").strip()
+    value = re.sub(r"^```(?:text|markdown)?", "", value, flags=re.IGNORECASE).strip()
+    value = re.sub(r"```$", "", value).strip()
+    value = re.sub(r"^(prompt|music prompt|answer)\s*:\s*", "", value, flags=re.IGNORECASE).strip()
+    value = value.strip("\"'` \n\r\t")
+    value = re.sub(r"\b\d{2,4}\s*(?:bpm|beats?\s+per\s+minute)\b,?\s*", "", value, flags=re.IGNORECASE)
+    value = re.sub(r"\s+", " ", value)
+    if "\n" in value:
+        value = value.splitlines()[0].strip()
+    clauses = [
+        clause.strip(" ,.;")
+        for clause in value.split(",")
+        if clause.strip(" ,.;")
+        and not re.search(r"\b(vocal|vocals|lyrics?|singer|singing|voice)\b", clause, flags=re.IGNORECASE)
+    ]
+    value = ", ".join(clauses) if clauses else value
+    return value[:MAX_PROMPT_CHARS].rstrip(" ,.;")
+
+
+def _generate_prompt_sync(payload: dict[str, Any]) -> dict[str, Any]:
+    import torch
+
+    tokenizer, model = _get_model()
+    current_prompt = str(payload.get("prompt") or "").strip()
+    negative_prompt = str(payload.get("negative_prompt") or "").strip()
+    seed_idea = random.choice(_SEEDS)
+
+    messages = [
+        {
+            "role": "system",
+            "content": (
+                "You write concise English prompts for an AI music generator. "
+                "Return exactly one comma-separated instrumental music prompt. "
+                "No explanations, no markdown, no lyrics, no vocals, no artist names, no BPM or tempo numbers."
+            ),
+        },
+        {
+            "role": "user",
+            "content": (
+                "Create a fresh high-quality music prompt. "
+                f"Seed idea: {seed_idea}. "
+                f"Current prompt to improve or replace: {current_prompt or 'none'}. "
+                f"Avoid: {negative_prompt or 'vocals, harsh noise, muddy mix'}. "
+                "Include genre, mood, rhythm, drums, bass, lead instruments, atmosphere, structure, and mix quality. "
+                "Do not include exact tempo or BPM."
+            ),
+        },
+    ]
+
+    prompt_text = tokenizer.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)
+    inputs = tokenizer(prompt_text, return_tensors="pt")
+
+    with torch.inference_mode():
+        output_ids = model.generate(
+            **inputs,
+            max_new_tokens=140,
+            do_sample=True,
+            temperature=0.9,
+            top_p=0.92,
+            repetition_penalty=1.08,
+            pad_token_id=tokenizer.eos_token_id,
+        )
+
+    generated_ids = output_ids[0][inputs["input_ids"].shape[-1] :]
+    text = tokenizer.decode(generated_ids, skip_special_tokens=True)
+    prompt = _clean_prompt(text)
+    if not prompt:
+        raise HTTPException(status_code=500, detail="Prompt LLM returned an empty prompt.")
+    return {"prompt": prompt, "model": MODEL_ID}
+
+
+@router.get("/status")
+def status() -> dict[str, Any]:
+    return {
+        "model": MODEL_ID,
+        "loaded": _tokenizer is not None and _model is not None,
+        "device": "cpu",
+    }
+
+
+@router.post("/generate")
+async def generate_prompt(payload: dict[str, Any] = Body(default_factory=dict)) -> dict[str, Any]:
+    if not isinstance(payload, dict):
+        payload = {}
+    return await asyncio.to_thread(_generate_prompt_sync, payload)
